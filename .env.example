# PostgreSQL connection string used by Payload
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# PostgreSQL schema name for CMS tables
DB_SCHEMA=cms

# Payload app secret for auth and internal security
PAYLOAD_SECRET=change-this-in-local-and-prod

# Public base URL of this CMS app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional UI deployment webhook triggered after published post changes
UI_DEPLOY_WEBHOOK_URL=

# Directory for rotated logs
LOG_DIR=logs

# Log filename pattern
LOG_FILENAME=application-%DATE%.log

# Date suffix format for rotated logs
LOG_DATE_PATTERN=YYYY-MM-DD

# Maximum size of one log file before rotation
LOG_MAX_SIZE=20m

# How long rotated logs are retained
LOG_MAX_FILES=14d

# Compress old rotated logs
LOG_ZIPPED_ARCHIVE=false

# Stable symlink name for the active log file
LOG_SYMLINK_NAME=current.log
