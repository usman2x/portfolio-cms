{
  "name": "portfolio-cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env scripts/run-with-rotating-logs.mjs next dev",
    "dev:plain": "next dev",
    "dev:logs": "node --env-file=.env scripts/run-with-rotating-logs.mjs next dev",
    "build": "next build",
    "start": "node scripts/run-with-rotating-logs.mjs next start",
    "start:plain": "next start",
    "start:logs": "node scripts/run-with-rotating-logs.mjs next start",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "generate:types": "npm run payload generate:types",
    "generate:importmap": "npm run payload generate:importmap",
    "migrate": "npm run payload migrate",
    "migrate:create": "npm run payload migrate:create",
    "migrate:init": "npm run migrate:create -- init-schema",
    "migrate:status": "npm run payload migrate:status",
    "db:check": "node --env-file=.env scripts/check-db-connection.mjs",
    "ci": "npm run migrate && npm run build"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "cross-env": "^7.0.3",
    "next": "^16.2.0",
    "payload": "^3.83.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}
